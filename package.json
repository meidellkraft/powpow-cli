		"rolldown": "1.0.0-rc.12"
	},
	"devDependencies": {
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22.17.0",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"typescript": ">=5.0.0"
	},
	"peerDependenciesMeta": {
