{
	"name": "powpow-cli",
	"version": "0.1.1",
	"description": "Pro-code development tool for Power Pages with TypeScript transpilation and local development server features.",
	"type": "module",
	"license": "ISC",
	"author": "Meidellkraft",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/meidellkraft/powpow-cli.git"
	},
	"bugs": {
		"url": "https://github.com/meidellkraft/powpow-cli/issues"
	},
	"homepage": "https://github.com/meidellkraft/powpow-cli#readme",
	"keywords": [
		"power-pages",
		"power-platform",
		"dataverse",
		"build-tool",
		"cli"
	],
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"powpow": "dist/cli.js"
	},
	"files": [
